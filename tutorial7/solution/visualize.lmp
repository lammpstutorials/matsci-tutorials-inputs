# LAMMPS Input File
# Licensed under CC BY 4.0
# Tutorial 7 -- render one frame of the fracture trajectory, colored by the
# per-atom stress sigma_yy (the pulling direction).
#
# Run fracture.lmp first to produce fracture.lammpstrj, then open this file in
# LAMMPS-GUI and run it (or: lmp -in visualize.lmp -var step <timestep>).
# Change "step" in the "Set Variables" dialog to show a different frame; the
# loaded state is near the stress peak and the cleaved state just after it.
variable step index 2714        # 2714 = loaded (near peak), 2905 = cleaved

units metal
dimension 3
boundary p s p
atom_style atomic

# topology and box come from the relaxed grain boundary; the chosen frame then
# overwrites the atom positions and the (deformed) box
read_data ../Fe_gb.data
pair_style eam/fs
pair_coeff * * ../Fe_mm.eam.fs Fe Fe
read_dump ../fracture.lammpstrj ${step} x y z box yes replace yes

# per-atom sigma_yy in GPa (stress/atom is pressure*volume; divide by the bcc
# atomic volume a0^3/2 and by 1e4)
compute satom all stress/atom NULL
variable a0 equal 2.855324
variable vatom equal ${a0}*${a0}*${a0}/2.0
variable syy atom c_satom[2]/v_vatom/10000.0
run 0

write_dump all image fracture-${step}.png v_syy type adiam 2.3 &
    view 0 0 zoom 2.7 size 1900 700 shiny 0.15 ssao yes 4539 0.5 fsaa yes &
    modify backcolor white boxcolor midnightblue &
    amap 0.0 22.0 ca 0.0 2 min steelblue max firebrick
