write_dump all custom random.dump id type x y z modify sort id

# 3) hybrid MD/MC: every 40 MD steps attempt 80 identity swaps for each
#    element pair, accepted with the Metropolis criterion at temperature T
fix s12 all atom/swap 40 80 701 ${T} types 1 2
fix s12 all atom/swap 40 80 701 700 types 1 2
fix s13 all atom/swap 40 80 702 ${T} types 1 3
fix s13 all atom/swap 40 80 702 700 types 1 3
fix s14 all atom/swap 40 80 703 ${T} types 1 4
fix s14 all atom/swap 40 80 703 700 types 1 4
fix s23 all atom/swap 40 80 704 ${T} types 2 3
fix s23 all atom/swap 40 80 704 700 types 2 3
fix s24 all atom/swap 40 80 705 ${T} types 2 4
fix s24 all atom/swap 40 80 705 700 types 2 4
fix s34 all atom/swap 40 80 706 ${T} types 3 4
fix s34 all atom/swap 40 80 706 700 types 3 4
# record the (smoothed) energy and dump snapshots for the order analysis
fix peout all ave/time 100 1 100 v_peat file energy.dat
dump traj all custom 500 anneal.dump id type x y z
dump_modify traj sort id
run 20000
