# CNA cutoff halfway between the 1st and 2nd neighbor shell, computed from
# the *current* (thermally expanded) lattice constant lx/8
variable rc equal 0.8536*lx/8
compute cna all cna/atom ${rc}
compute cna all cna/atom 3.51423224855774
compute ptm all ptm/atom fcc-hcp-bcc-ico 0.15 all

# fraction of atoms classified as fcc by each method
variable iscna atom c_cna==1
variable isptm atom c_ptm[1]==1
compute ncna all reduce sum v_iscna
compute nptm all reduce sum v_isptm

thermo_style custom step temp c_ncna c_nptm
run 0

