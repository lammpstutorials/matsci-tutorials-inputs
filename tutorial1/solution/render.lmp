# Tutorial 1 figure generator: render the fcc aluminum crystal.
# Run twice:
#   lmp -in render.lmp                              # naive fcc cell   -> metals-fcc.0.png
#   lmp -in render.lmp -var o 0.25 -var tag shift   # shifted fcc cell -> metals-shift.0.png

variable o   index 0.0
variable tag index fcc

units metal
dimension 3
boundary p p p
atom_style atomic

lattice fcc 4.05 origin ${o} ${o} ${o}
region box block 0 4 0 4 0 4
create_box 1 box
create_atoms 1 box

pair_style eam/alloy
pair_coeff * * Al_zhou.eam.alloy Al

dump d1 all image 1 metals-${tag}.*.png type type &
     adiam 2.6 view 60 -40 zoom 1.2 box yes 0.028 size 1200 1200 &
     shiny 0.15 ssao yes 4539 0.5 fsaa yes
dump_modify d1 backcolor white acolor 1 gray boxcolor midnightblue

run 0
