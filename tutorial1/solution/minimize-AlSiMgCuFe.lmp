# Tutorial 1 -- potential comparison (solution only)
# Same calculation as minimize.lmp but with the Jelinek et al. multi-element
# MEAM potential, restricted to aluminum. MEAM is a more advanced (modified
# EAM) model with separately tunable inter-element interactions.
# The element labels (AlS SiS MgS CuS FeS) follow the AlSiMgCuFe.meam header:
# library.meam also contains other "Al" entries with different parameters.

units metal
dimension 3
boundary p p p
atom_style atomic

lattice fcc 4.05 origin 0.25 0.25 0.25
region box block 0 4 0 4 0 4
create_box 1 box
create_atoms 1 box

pair_style meam
pair_coeff * * library.meam AlS SiS MgS CuS FeS AlSiMgCuFe.meam AlS

thermo 10
thermo_style custom step pe press lx

fix relax all box/relax iso 0.0 vmax 0.001
min_style cg
minimize 1.0e-12 1.0e-12 10000 100000

variable a0   equal lx/4
variable ecoh equal pe/count(all)
print "POTENTIAL AlSiMgCuFe.meam (meam): a0 = ${a0} Ang  ecoh = ${ecoh} eV/atom"
