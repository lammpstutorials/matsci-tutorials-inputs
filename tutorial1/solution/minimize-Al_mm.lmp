# LAMMPS Input File
# Licensed under CC BY 4.0
# Tutorial 1 -- potential comparison (solution only)
# Same calculation as minimize.lmp but with the Mendelev Al EAM potential
# in Finnis-Sinclair file format (eam/fs). For a single element this is the
# same EAM model as eam/alloy, only the file format differs.

units metal
dimension 3
boundary p p p
atom_style atomic

lattice fcc 4.05 origin 0.25 0.25 0.25
region box block 0 4 0 4 0 4
create_box 1 box
create_atoms 1 box

pair_style eam/fs
pair_coeff * * Al_mm.eam.fs Al

thermo 10
thermo_style custom step pe press lx

fix relax all box/relax iso 0.0 vmax 0.001
min_style cg
minimize 1.0e-12 1.0e-12 10000 100000

variable a0   equal lx/4
variable ecoh equal pe/count(all)
print "POTENTIAL Al_mm.eam.fs (eam/fs): a0 = ${a0} Ang  ecoh = ${ecoh} eV/atom"
