# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package: 2. Materials Science
# By Simon Gravelle, Mark A. Tschopp, Jacob R. Gissinger, and Axel Kohlmeyer
# Tutorial 1: 3. Check for translation invariance

# 1) Initialization
units metal
dimension 3
boundary p p p
atom_style atomic

# 2) System definition
# Shift the lattice origin by a quarter spacing so that no atoms sit exactly
# on the box faces (fcc has lattice planes every half spacing, so a 0.5 region
# shift would still land on the face-centered plane).
lattice fcc 4.049 origin 0.25 0.25 0.25
region box block 0 4 0 4 0 4
create_box 1 box
create_atoms 1 box

# 3) Settings
pair_style eam/alloy
pair_coeff * * Al_zhou.eam.alloy Al

compute eng all pe/atom
compute eatoms all reduce sum c_eng

# 4) Monitoring
thermo 10
thermo_style custom step pe c_eatoms press lx pxx pyy pzz

# 5) Run
fix relax all box/relax iso 0.0 vmax 0.001
min_style cg
minimize 1.0e-12 1.0e-12 10000 100000

# results -- should match minimize.lmp (translation invariance under PBC)
variable ncell equal 4
variable a0    equal lx/v_ncell
variable ecoh  equal pe/count(all)
print "------- EAM: Al_zhou.eam.alloy ---------------------"
print "Number of atoms        = $(count(all))"
print "Equilibrium a0 (Ang)   = ${a0}"
print "Cohesive energy (eV)   = ${ecoh}"
print "----------------------------------------------------"
