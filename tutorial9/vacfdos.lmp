# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Tutorial 9: phonon dispersion from MD -- vibrational density of states
#
# Record the velocity autocorrelation function (VACF) of the same copper
# crystal at 300 K.  Its Fourier transform is the vibrational density of
# states g(nu) -- the "integral view" of the dispersion curves -- from which
# dos-plot.py also computes the (quantum) harmonic heat capacity.  Uses a
# conventional fcc cell at the 300 K lattice constant, equilibrated with a
# thermostat and sampled in the NVE ensemble so that no thermostat damping
# distorts the spectrum.

variable a0 equal 3.6318          # thermally expanded, as in phonon.lmp
variable T  equal 300.0

units metal
atom_style atomic
boundary p p p

lattice fcc ${a0}
region box block 0 8 0 8 0 8
create_box 1 box
create_atoms 1 box
mass 1 63.546
pair_style eam/alloy
pair_coeff * * Cu_mishin1.eam.alloy Cu

# thermalize at T (target 2T initial kinetic energy, half goes potential)
velocity all create $(2.0*v_T) 87287 mom yes rot yes dist gaussian
fix nvt all nvt temp ${T} ${T} 0.1
thermo 500
thermo_style custom step temp pe press
run 5000
unfix nvt

# production: NVE, record the VACF every step for 20 ps
fix nve all nve
compute vacf all vacf
fix rec all ave/time 1 1 1 c_vacf[4] file vacf.dat
run 20000
