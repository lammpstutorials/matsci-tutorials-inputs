# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Modernized recreation of the MSU/CAVS tutorials by Mark A. Tschopp
# Tutorial 9: elastic constants of crystalline silicon (Stillinger-Weber).
#
# The full 6x6 stiffness matrix C_ij is obtained by deforming the relaxed
# diamond-cubic cell by a small strain in each of the six Voigt directions,
# relaxing the internal atom positions at fixed box shape, and recording the
# resulting stress tensor.  C_ij = d(sigma_i)/d(eps_j) is the slope of the
# stress-strain response, so each direction is scanned over a range of small
# strains and the slopes are fitted afterwards by plot.py.
#
# Strategy (compare Tutorial 2): the relaxed cell is written once to a data
# file, then an in-LAMMPS double loop over the six directions and a list of
# strains re-reads that reference cell, deforms it, and appends one record per
# (direction, strain) to a structured YAML file.  Reload the reference for
# every case so the strains are always measured from the same zero-stress
# state.

# ---------------------------------------------------------------------------
# 1) Equilibrium reference: relax box and atoms to zero pressure
# ---------------------------------------------------------------------------
units metal
boundary p p p
atom_style atomic

variable a0 equal 5.43                  # SW silicon lattice constant (Angstrom)
lattice diamond ${a0}
region box prism 0 3 0 3 0 3 0 0 0      # prism box so shear (tilt) is allowed
create_box 1 box
create_atoms 1 box
mass 1 28.0855

pair_style sw
pair_coeff * * Si.sw Si

min_style cg
min_modify dmax 0.01 line quadratic
thermo 50
thermo_style custom step pe press pxx pyy pzz pyz pxz pxy lx ly lz

# relax cell shape and volume to zero stress (aniso: each axis independently)
fix relax all box/relax aniso 0.0
minimize 0.0 1.0e-12 1000 10000
unfix relax

# save the relaxed reference cell and capture its edge lengths as constants.
# The $(...) form is an immediate (anonymous) variable expansion: it is
# evaluated now, during input processing (like ${a0}), and freezes the value
# into a plain number, so these constants still work after "clear" rebuilds
# the box in the loop below.
write_data Si_equil.data
variable lx0 equal $(lx)
variable ly0 equal $(ly)
variable lz0 equal $(lz)

# ---------------------------------------------------------------------------
# 2) Scan a small strain in each of the six Voigt directions
# ---------------------------------------------------------------------------
# YAML output: one record per (direction, strain) with the pressure tensor.
# Stress is the negative of the pressure; plot.py negates and converts to GPa.
print "# elastic constants of SW silicon" file scan.yaml screen no
print "# dir = Voigt direction 1..6 (xx yy zz yz xz xy)" append scan.yaml screen no
print "# eps = applied strain; pressures pij in bar" append scan.yaml screen no

variable dir loop 6
label dirloop

  # (re)create the strain list at the start of each direction
  variable eps index -0.008 -0.006 -0.004 -0.002 0.002 0.004 0.006 0.008
  label epsloop

    # reload the zero-stress reference; clear resets units, so set them again
    clear
    units metal
    read_data Si_equil.data
    pair_style sw
    pair_coeff * * Si.sw Si
    min_style cg
    min_modify dmax 0.01 line quadratic

    # reference length for this direction (normal: own axis; shear: see below)
    if "${dir} == 1" then "variable len0 equal ${lx0}"
    if "${dir} == 2" then "variable len0 equal ${ly0}"
    if "${dir} == 3" then "variable len0 equal ${lz0}"
    if "${dir} == 4" then "variable len0 equal ${lz0}"
    if "${dir} == 5" then "variable len0 equal ${lz0}"
    if "${dir} == 6" then "variable len0 equal ${ly0}"
    variable d equal ${eps}*${len0}     # box change in distance units

    # apply the strain: directions 1-3 stretch an edge, 4-6 add a tilt
    if "${dir} == 1" then "change_box all x  delta 0 ${d} remap units box"
    if "${dir} == 2" then "change_box all y  delta 0 ${d} remap units box"
    if "${dir} == 3" then "change_box all z  delta 0 ${d} remap units box"
    if "${dir} == 4" then "change_box all yz delta ${d}   remap units box"
    if "${dir} == 5" then "change_box all xz delta ${d}   remap units box"
    if "${dir} == 6" then "change_box all xy delta ${d}   remap units box"

    # relax the internal coordinates only (box shape stays fixed)
    minimize 0.0 1.0e-12 1000 10000

    print "- {dir: ${dir}, eps: ${eps}, pxx: $(pxx:%.6f), pyy: $(pyy:%.6f), &
        pzz: $(pzz:%.6f), pyz: $(pyz:%.6f), pxz: $(pxz:%.6f), &
        pxy: $(pxy:%.6f)}" append scan.yaml screen no

    variable len0 delete
    variable d delete
  next eps
  jump SELF epsloop

next dir
jump SELF dirloop

print "Elastic strain scan complete; results written to scan.yaml"
