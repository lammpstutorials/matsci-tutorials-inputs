variable ishcp atom "c_cna == 2"
group hcp variable ishcp
15 atoms in group hcp
variable dwid equal sqrt((bound(hcp,xmax)-bound(hcp,xmin))^2+(bound(hcp,ymax)-bound(hcp,ymin))^2)
print "--------------------------------------------------"
