# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Tutorial 6: tensile failure of a pure vs an alloyed aluminum nanowire.
#
# Pure aluminum is soft; engineering alloys gain their strength from
# solutes and precipitates.  This input pulls the same <100> nanowire to
# 100% strain twice -- once as pure Al and once as a random Al-10at%Cu
# solid solution -- using the same Al-Cu angular-dependent EAM potential
# (Apostol and Mishin, Phys. Rev. B 83, 054116 (2011)) for both, so that
# the difference is caused by the copper atoms alone.  Compare the stress-strain curves and the
# trajectories: the solutes strengthen the wire and change where and how
# it necks.  Analysis/visualization: solution/wire-alloy-plot.py and
# solution/wireviz.lmp.

variable xcu     index 0 10      # at% copper: pure first, then the alloy
variable temp    equal 300.0
variable nequil  equal 20000     # equilibration steps (20 ps)
variable ndeform equal 100000    # deformation steps (-> strain 1.0)

units metal
dimension 3
boundary p s s
atom_style atomic

variable a0 equal 4.049
lattice fcc ${a0} orient x 1 0 0 orient y 0 1 0 orient z 0 0 1 &
        origin 0.25 0.25 0.25
region box block 0 20 -6 6 -6 6
create_box 2 box
region wire cylinder x 0.0 0.0 4.0 INF INF
create_atoms 1 region wire

# turn xcu percent of the atoms into copper
variable ncu equal floor(count(all)*v_xcu/100.0)
if "${ncu} > 0" then "set group all type/subset 2 ${ncu} 75847"

mass 1 26.9815
mass 2 63.546
pair_style adp
pair_coeff * * AlCu.adp Al Cu

compute csym all centro/atom fcc
compute pea  all pe/atom
compute satom all stress/atom NULL

timestep 0.001
velocity all create ${temp} 12345 mom yes rot no
fix equi all npt temp ${temp} ${temp} 0.1 x 0.0 0.0 1.0
thermo 1000
thermo_style custom step temp pe lx
run ${nequil}
unfix equi

variable lx0 equal $(lx)
reset_timestep 0

fix integrate all nvt temp ${temp} ${temp} 0.1
fix shape all deform 1 x erate 0.01 units box remap x

compute sxxsum all reduce sum c_satom[1]
variable vat    equal v_a0*v_a0*v_a0/4.0
variable strain equal (lx-v_lx0)/v_lx0
variable sxx    equal c_sxxsum/(count(all)*v_vat)/10000.0
fix out all print 100 "$(v_strain:%.5f),$(v_sxx:%.5f)" &
    file stress-wire-${xcu}.csv title "strain,sxx_GPa" screen no

dump traj all custom 5000 wire-${xcu}.lammpstrj id type xs ys zs c_csym
dump_modify traj sort id

thermo_style custom step v_strain temp v_sxx pe
run ${ndeform}

print "RESULT xcu=${xcu} done"

clear
next xcu
jump SELF
