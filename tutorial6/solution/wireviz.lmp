# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Tutorial 6: render snapshots of the stretched nanowires of wire-alloy.lmp.
#
# Rebuilds the wire with the same type/subset seed as wire-alloy.lmp (which
# reproduces the same random copper decoration), overlays the positions of
# the requested trajectory frame with read_dump, and renders the wire viewed
# from the side: aluminum in light grey, copper in firebrick.
#   -v xcu  <0|10>     which run            (default 10)
#   -v step <N>        which timestep       (default 60000 = strain 0.6)

variable xcu  index 10
variable step index 60000

units metal
dimension 3
boundary p s s
atom_style atomic

variable a0 equal 4.049
lattice fcc ${a0} orient x 1 0 0 orient y 0 1 0 orient z 0 0 1 &
        origin 0.25 0.25 0.25
region box block 0 20 -6 6 -6 6
create_box 2 box
region wire cylinder x 0.0 0.0 4.0 INF INF
create_atoms 1 region wire

variable ncu equal floor(count(all)*v_xcu/100.0)
if "${ncu} > 0" then "set group all type/subset 2 ${ncu} 75847"

mass 1 26.9815
mass 2 63.546
pair_style zero 3.0
pair_coeff * *

read_dump wire-${xcu}.lammpstrj ${step} x y z box yes scaled yes

write_dump all image wire-${xcu}-${step}.png type type size 1600 320 &
    view 0 0 up 0 1 0 zoom 4.0 shiny 0.2 ssao yes 4539 0.6 fsaa yes &
    modify backcolor white boxcolor midnightblue &
    acolor 1 lightgrey acolor 2 firebrick adiam 1 2.6 adiam 2 2.9
