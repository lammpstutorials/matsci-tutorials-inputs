unfix equi

# reference length for the engineering strain
variable lx0 equal $(lx)
variable lx0 equal 80.225879817157675689
reset_timestep 0

# 5) Tension along the wire axis at +0.01/ps; the free surfaces handle the
#    lateral contraction by themselves -- no barostat needed
fix integrate all nvt temp ${temp} ${temp} 0.1
fix integrate all nvt temp 300.0 ${temp} 0.1
fix integrate all nvt temp 300.0 300.0 0.1
fix shape all deform 1 x erate 0.01 units box remap x

# axial stress from the per-atom stress over the wire volume: the global
# pressure would be diluted by the empty box space, so sum the per-atom
# stress (bar*Angstrom^3; its sum equals -pressure*volume) and divide by
# the wire volume, N times the atomic volume a0^3/4; /10^4 converts to GPa.
compute sxxsum all reduce sum c_satom[1]
variable vat    equal v_a0*v_a0*v_a0/4.0
variable strain equal (lx-v_lx0)/v_lx0
variable sxx    equal c_sxxsum/(count(all)*v_vat)/10000.0
fix out all print 100 "$(v_strain:%.5f),$(v_sxx:%.5f)"     file stress-wire.csv title "strain,sxx_GPa" screen no

dump traj all custom 1000 deform-wire.dump id type xs ys zs c_csym c_pea

thermo_style custom step v_strain temp v_sxx pe
run ${ndeform}
run 20000
