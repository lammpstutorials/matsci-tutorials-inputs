# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Tutorial 6: uniaxial tension of an aluminum nanowire.
#
# Same loading protocol as deform.lmp of Tutorial 5, but on a cylindrical
# <100> nanowire (~3.2 nm diameter) with free surfaces instead of a bulk.
# Two things change with free surfaces: the stress must be computed from the
# per-atom stress over the wire volume (the global pressure is diluted by
# the empty space in the box), and yielding starts at the surface, at a
# noticeably lower stress than the homogeneous nucleation of the bulk run.
# Compare with solution/wire-plot.py.

variable temp    index 300.0
variable nequil  index 20000     # equilibration steps (20 ps)
variable ndeform index 20000     # deformation steps (-> strain 0.2)

# 1) Initialization
units metal
dimension 3
boundary p s s                   # periodic along the wire axis only
atom_style atomic

# 2) System definition: <100> fcc Al wire, radius 4 cells (~3.2 nm diameter), 20 cells long
variable a0 equal 4.049
lattice fcc ${a0} orient x 1 0 0 orient y 0 1 0 orient z 0 0 1 &
        origin 0.25 0.25 0.25
region box block 0 20 -6 6 -6 6
create_box 1 box
region wire cylinder x 0.0 0.0 4.0 INF INF
create_atoms 1 region wire

# 3) Settings
pair_style eam/alloy
pair_coeff * * Al_zhou.eam.alloy Al

compute csym all centro/atom fcc
compute pea  all pe/atom
compute satom all stress/atom NULL

# 4) Equilibration: thermostat the wire and relax its length (axial stress 0)
timestep 0.001
velocity all create ${temp} 12345 mom yes rot no
fix equi all npt temp ${temp} ${temp} 0.1 x 0.0 0.0 1.0
thermo 1000
thermo_style custom step temp pe lx
run ${nequil}
unfix equi

# reference length for the engineering strain
variable lx0 equal $(lx)
reset_timestep 0

# 5) Tension along the wire axis at +0.01/ps; the free surfaces handle the
#    lateral contraction by themselves -- no barostat needed
fix integrate all nvt temp ${temp} ${temp} 0.1
fix shape all deform 1 x erate 0.01 units box remap x

# axial stress from the per-atom stress over the wire volume: the global
# pressure would be diluted by the empty box space, so sum the per-atom
# stress (bar*Angstrom^3; its sum equals -pressure*volume) and divide by
# the wire volume, N times the atomic volume a0^3/4; /10^4 converts to GPa.
compute sxxsum all reduce sum c_satom[1]
variable vat    equal v_a0*v_a0*v_a0/4.0
variable strain equal (lx-v_lx0)/v_lx0
variable sxx    equal c_sxxsum/(count(all)*v_vat)/10000.0
fix out all print 100 "$(v_strain:%.5f),$(v_sxx:%.5f)" &
    file stress-wire.csv title "strain,sxx_GPa" screen no

dump traj all custom 1000 deform-wire.lammpstrj id type xs ys zs c_csym c_pea

thermo_style custom step v_strain temp v_sxx pe
run ${ndeform}

print "Nanowire tension complete."
