# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Tutorial 13, part 1: phonon dispersion of fcc copper from molecular dynamics.
#
# fix phonon accumulates the displacement-displacement correlations of the
# crystal in reciprocal space during an ordinary finite-temperature MD run.
# From the fluctuation-dissipation theorem these give the force-constant
# (dynamical) matrix at every commensurate wave vector; diagonalizing it
# yields the phonon frequencies.  The result is written to a binary file that
# the bundled "phana" post-processor turns into a dispersion curve.
#
# The crystal is the fcc PRIMITIVE cell -- one atom, so three phonon branches
# and no band folding.  That cell is a 60-degree rhombohedron, so the box is
# triclinic.  It is built below directly with the lattice/create_atoms
# commands (no external structure file): the three primitive vectors a1,a2,a3
# (in units of the lattice constant) are handed to "lattice custom", and the
# box is a prism whose edges are N copies of those vectors.  The companion
# file map.in tells fix phonon which unit cell (l1,l2,l3) each atom sits in;
# because the box edges ARE the primitive vectors, an atom's scaled
# coordinates are exactly (l1,l2,l3)/N, which is how map.in was generated.
#
# NOTE: this is the most demanding input in the set.  The high-frequency
# longitudinal branch needs long sampling, so the run is several million
# steps (~5 min on 8 threads, much longer single-threaded).  Enable threads
# under Preferences->Accelerators and, ideally, run it in the background.

units       metal
atom_style  atomic
boundary    p p p

# --- build the fcc primitive-cell supercell (N x N x N) ---
variable    a0 equal 3.6318                 # Cu (Mishin EAM) 300 K lattice const.
variable    N  equal 8                      # supercell size (must match map.in)
variable    s  equal ${a0}/sqrt(2.0)        # primitive edge length = a0/sqrt(2)
variable    s  equal 3.6318/sqrt(2.0)        
variable    lx equal ${s}                   # primitive-cell box edges ...
variable    lx equal 2.5680704079133                   
variable    ly equal ${s}*sqrt(3.0)/2.0
variable    ly equal 2.5680704079133*sqrt(3.0)/2.0
variable    lz equal ${s}*sqrt(2.0/3.0)
variable    lz equal 2.5680704079133*sqrt(2.0/3.0)
variable    ty equal ${s}/2.0               # ... and tilt factors
variable    ty equal 2.5680704079133/2.0               
variable    tz equal ${s}/(2.0*sqrt(3.0))
variable    tz equal 2.5680704079133/(2.0*sqrt(3.0))

lattice     custom ${a0}                                      a1 0.7071068 0.0       0.0                        a2 0.3535534 0.6123724 0.0                        a3 0.3535534 0.2041241 0.5773503                  basis 0.0 0.0 0.0
lattice     custom 3.6318                                      a1 0.7071068 0.0       0.0                        a2 0.3535534 0.6123724 0.0                        a3 0.3535534 0.2041241 0.5773503                  basis 0.0 0.0 0.0
Lattice spacing in x,y,z = 5.136141 2.965352 2.0968208
region      box prism 0 $(v_N*v_lx) 0 $(v_N*v_ly) 0 $(v_N*v_lz)             $(v_N*v_ty) $(v_N*v_ty) $(v_N*v_tz) units box
region      box prism 0 20.544563263306400813 0 $(v_N*v_ly) 0 $(v_N*v_lz)             $(v_N*v_ty) $(v_N*v_ty) $(v_N*v_tz) units box
region      box prism 0 20.544563263306400813 0 17.792113695679841356 0 $(v_N*v_lz)             $(v_N*v_ty) $(v_N*v_ty) $(v_N*v_tz) units box
region      box prism 0 20.544563263306400813 0 17.792113695679841356 0 16.774565661143039819             $(v_N*v_ty) $(v_N*v_ty) $(v_N*v_tz) units box
region      box prism 0 20.544563263306400813 0 17.792113695679841356 0 16.774565661143039819             10.272281631653200407 $(v_N*v_ty) $(v_N*v_tz) units box
region      box prism 0 20.544563263306400813 0 17.792113695679841356 0 16.774565661143039819             10.272281631653200407 10.272281631653200407 $(v_N*v_tz) units box
region      box prism 0 20.544563263306400813 0 17.792113695679841356 0 16.774565661143039819             10.272281631653200407 10.272281631653200407 5.9307045652266241476 units box
create_box  1 box
