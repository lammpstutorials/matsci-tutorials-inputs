unfix equi

# 4) production: hold the temperature and volume fixed (NVT) and accumulate
#    the mean-squared displacement, removing any center-of-mass drift.  A
#    gentle Nose-Hoover thermostat keeps every run exactly at its target
#    temperature, which a plain constant-energy (NVE) run cannot guarantee.
reset_timestep 0
fix nvt all nvt temp ${T} ${T} 0.2
fix nvt all nvt temp 1000 ${T} 0.2
fix nvt all nvt temp 1000 1000 0.2
compute msd all msd com yes
fix outmsd all ave/time 100 1 100 c_msd[4] file msd_${T}.dat
fix outmsd all ave/time 100 1 100 c_msd[4] file msd_1000.dat
# live, rough estimate of D from the running MSD slope (the careful fit that
# excludes the early ballistic regime is done in plot.py); D = slope/(2*dim)
fix vec all vector 10 c_msd[4]
variable dcoef equal slope(f_vec)/6.0/(10*dt)
thermo 2000
thermo_style custom step temp pe press vol c_msd[4] v_dcoef
run 100000
