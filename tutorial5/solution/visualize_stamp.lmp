# LAMMPS Input File
# Licensed under CC BY 4.0
# Tutorial 6 (nano-stamping) -- render the tool and the imprint it leaves.
#
# Run stamp.lmp first to produce stamp.dump, then open this file in LAMMPS-GUI
# and run it (or: lmp -in visualize_stamp.lmp).  The structure is briefly
# energy-minimized to remove thermal noise, then the substrate is viewed from
# above and colored by height so the stamped imprint stands out, and the tool
# is drawn on its own.
variable step index 21000        # frame to show (after the tool has lifted off)

units metal
dimension 3
boundary p p f
atom_style atomic

# rebuild substrate + tool so the dump frame can be read back onto them
variable a0 equal 4.05
lattice fcc ${a0}
region box  block -14 14 -14 14 -0.1 20 units lattice
create_box 2 box
region slab block -14 14 -14 14 -0.1 8 units lattice
create_atoms 1 region slab
mass 1 26.9815
mass 2 12.011
group sub type 1
variable ztop equal bound(sub,zmax)
create_atoms 2 mesh ../tool.stl meshmode bisect 2.0 units box
group tool type 2
displace_atoms tool move 0.0 0.0 $(v_ztop+4.0) units box

pair_style hybrid eam/alloy lj/cut 5.0
pair_coeff * * eam/alloy ../Al_zhou.eam.alloy Al NULL
pair_coeff 1 2 lj/cut 0.10 2.5
pair_coeff 2 2 lj/cut 0.10 2.5
neigh_modify exclude group tool tool one 10000 page 200000

read_dump ../stamp.dump ${step} x y z box yes replace yes

# freeze the fixed bottom and the (lifted) tool, then relax to remove thermal
# noise so the static imprint is sharp
variable zlo equal bound(sub,zmin)
region rbot block INF INF INF INF INF $(v_zlo+1.5*v_a0) units box
group bottom region rbot
group bottom intersect bottom sub
fix f1 bottom setforce 0.0 0.0 0.0
fix f2 tool setforce 0.0 0.0 0.0
min_style cg
minimize 1.0e-8 1.0e-8 400 4000

# the imprint: substrate viewed from above, colored by height
variable zc atom z
write_dump sub image imprint.png v_zc type adiam 2.8 &
    view 0 0 up 0 1 0 zoom 1.55 size 1100 1100 shiny 0.15 ssao yes 4539 0.5 fsaa yes &
    modify backcolor white boxcolor midnightblue &
    amap $(v_ztop-10.0) $(v_ztop+2.0) ca 0.0 3 min firebrick $(v_ztop-4.0) gold max steelblue

# the tool on its own (the winking smiley)
write_dump tool image tool-face.png type type adiam 2.0 &
    view 0 0 up 0 1 0 zoom 1.7 size 1100 1100 fsaa yes &
    modify backcolor white acolor 2 goldenrod

print "Frame ${step}: rendered imprint.png and tool-face.png"
