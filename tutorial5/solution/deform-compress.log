unfix equi

# reference length for the engineering strain
variable lx0 equal $(lx)
variable lx0 equal 41.121720916677020341
reset_timestep 0

# 5) Uniaxial deformation along x at constant engineering strain rate
#    +0.01/ps (tension) or -0.01/ps (compression); lateral sides at 0 bar
if "${mode} == compress" then "variable erate equal -0.01" else "variable erate equal 0.01"
variable erate equal -0.01
fix integrate all npt temp ${temp} ${temp} 0.1 y 0.0 0.0 1.0 z 0.0 0.0 1.0
fix integrate all npt temp 300.0 ${temp} 0.1 y 0.0 0.0 1.0 z 0.0 0.0 1.0
fix integrate all npt temp 300.0 300.0 0.1 y 0.0 0.0 1.0 z 0.0 0.0 1.0
fix shape all deform 1 x erate ${erate} units box remap x
fix shape all deform 1 x erate -0.01 units box remap x

# stress-strain output (engineering strain; stress in GPa = -pressure/10000)
variable strain equal (lx-v_lx0)/v_lx0
variable sxx equal -pxx/10000.0
variable syy equal -pyy/10000.0
variable szz equal -pzz/10000.0
fix out all print 100 "$(v_strain:%.5f),$(v_sxx:%.5f),$(v_syy:%.5f),$(v_szz:%.5f)"     file stress-${mode}.csv title "strain,sxx_GPa,syy_GPa,szz_GPa" screen no
fix out all print 100 "$(v_strain:%.5f),$(v_sxx:%.5f),$(v_syy:%.5f),$(v_szz:%.5f)"     file stress-compress.csv title "strain,sxx_GPa,syy_GPa,szz_GPa" screen no

# trajectory for OVITO/LAMMPS-GUI, and colored snapshots by centrosymmetry
dump traj all custom 1000 deform-${mode}.dump id type xs ys zs c_csym c_pea
dump traj all custom 1000 deform-compress.dump id type xs ys zs c_csym c_pea
dump img all image 2000 deform-${mode}-*.png c_csym type      adiam 2.6 view 60 -40 zoom 1.35 box yes 0.02 size 1000 1000      shiny 0.15 ssao yes 4539 0.5 fsaa yes
dump img all image 2000 deform-compress-*.png c_csym type      adiam 2.6 view 60 -40 zoom 1.35 box yes 0.02 size 1000 1000      shiny 0.15 ssao yes 4539 0.5 fsaa yes
dump_modify img backcolor white amap 0.0 10.0 ca 0.0 2 min steelblue max firebrick

thermo_style custom step v_strain temp v_sxx v_syy v_szz pe press
run ${ndeform}
run 20000
