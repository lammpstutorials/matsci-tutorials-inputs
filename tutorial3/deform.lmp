# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Modernized recreation of the MSU/CAVS tutorials by Mark A. Tschopp
# Tutorial 3: uniaxial deformation of single-crystal aluminum.
#
# Loading mode is set by the index variable "mode": "tension" (default) or
# "compress"; set it in the LAMMPS-GUI "Set Variables" dialog or with
#   lmp -in deform.lmp -var mode compress
variable mode    index tension
variable temp    index 300.0     # temperature in K (try 10 for clearer defect images)
variable nequil  index 20000     # equilibration steps (20 ps)
variable ndeform index 20000     # deformation steps (-> strain 0.2)

# 1) Initialization
units metal
dimension 3
boundary p p p
atom_style atomic

# 2) System definition: <100>-oriented fcc Al, 10x10x10 cells (4000 atoms)
variable a0 equal 4.049
lattice fcc ${a0} orient x 1 0 0 orient y 0 1 0 orient z 0 0 1 &
        origin 0.25 0.25 0.25
region box block 0 10 0 10 0 10
create_box 1 box
create_atoms 1 box

# 3) Settings
pair_style eam/alloy
pair_coeff * * Al_zhou.eam.alloy Al

compute csym all centro/atom fcc
compute pea  all pe/atom

# 4) Equilibration at the target temperature and zero pressure (isotropic NPT)
timestep 0.001
velocity all create ${temp} 12345 mom yes rot no
fix equi all npt temp ${temp} ${temp} 0.1 iso 0.0 0.0 1.0
thermo 1000
thermo_style custom step temp pe lx ly lz press
run ${nequil}
unfix equi

# reference length for the engineering strain
variable lx0 equal $(lx)
reset_timestep 0

# 5) Uniaxial deformation along x at constant engineering strain rate
#    +0.01/ps (tension) or -0.01/ps (compression); lateral sides at 0 bar
if "${mode} == compress" then "variable erate equal -0.01" else "variable erate equal 0.01"
fix integrate all npt temp ${temp} ${temp} 0.1 y 0.0 0.0 1.0 z 0.0 0.0 1.0
fix shape all deform 1 x erate ${erate} units box remap x

# stress-strain output (engineering strain; stress in GPa = -pressure/10000)
variable strain equal (lx-v_lx0)/v_lx0
variable sxx equal -pxx/10000.0
variable syy equal -pyy/10000.0
variable szz equal -pzz/10000.0
fix out all print 100 "$(v_strain:%.5f),$(v_sxx:%.5f),$(v_syy:%.5f),$(v_szz:%.5f)" &
    file stress-${mode}.csv title "strain,sxx_GPa,syy_GPa,szz_GPa" screen no

# trajectory for LAMMPS-GUI/OVITO, with per-atom centrosymmetry for coloring;
# turn it into the dislocation figure with solution/visualize.lmp
dump traj all custom 1000 deform-${mode}.dump id type xs ys zs c_csym c_pea

thermo_style custom step v_strain temp v_sxx v_syy v_szz pe press
run ${ndeform}

print "Deformation (${mode}) complete."
