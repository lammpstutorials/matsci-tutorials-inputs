# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package: 2. Materials Science
# By Simon Gravelle, Mark A. Tschopp, Jacob R. Gissinger, and Axel Kohlmeyer
# Tutorial 3: 2. Self-interstitial formation energy (<100> dumbbell)
#
# Same protocol as vacancy.lmp, but an atom is ADDED instead of removed: the
# atom at the central lattice site is displaced along -x and a new atom is
# created at the mirror position, so that after relaxation the two atoms
# share one lattice site as a <100> split interstitial (dumbbell).  The
# formation energy follows from the energy balance
#     Ef(int) = E(N+1) - (N+1)/N * E(N)

# 1) Initialization
units metal
dimension 3
boundary p p p
atom_style atomic

# 2) System definition
variable ncell index 6           # supercell size in conventional fcc cells
variable a0 index 4.08165        # Zhou EAM equilibrium value from Tutorial 1
variable dsep index 0.85         # half-separation used to seed the dumbbell
lattice fcc ${a0} origin 0.25 0.25 0.25
region box block 0 ${ncell} 0 ${ncell} 0 ${ncell}
create_box 1 box
create_atoms 1 box

# 3) Settings
pair_style eam/alloy
pair_coeff * * Al_zhou.eam.alloy Al

# 4) Monitoring
thermo 10
thermo_style custom step pe press fnorm

# 5) Reference energy of the perfect crystal
fix move all nve
run 0 post no
variable natoms0 equal $(count(all))
variable epe0    equal $(pe)

# 6) Seed the <100> dumbbell at the central lattice site: displace the
#    resident atom by -dsep along x, then add the new atom at +dsep
variable rc equal (floor(v_ncell/2)+0.25)*v_a0
region site sphere $(v_rc) $(v_rc) $(v_rc) 0.5 units box
group central region site
displace_atoms central move -${dsep} 0.0 0.0 units box
create_atoms 1 single $(v_rc+v_dsep) $(v_rc) $(v_rc) units box

# 7) Relax the atomic positions at fixed box size
min_style cg
minimize 1.0e-10 1.0e-12 10000 100000

# 8) Formation energy from the energy balance
variable efint equal pe-(v_natoms0+1)/v_natoms0*v_epe0
print "--------------------------------------------"
print "Atoms in the perfect cell       = ${natoms0}"
print "Interstitial formation energy   = $(v_efint:%.4f) eV"
print "--------------------------------------------"

# 9) Save the relaxed configuration for visualization (see solution folder)
write_data interstitial.data
