if "${mode} == bulk" then   "variable arel equal lx/2"   "variable crel equal lz/2"   "variable dens equal mass(all)/vol*1.66054"   "print '--------------------------------------------------'"   "print 'QUARTZ ${pot}: a = $(v_arel:%.4f)  c = $(v_crel:%.4f)  (exp. 4.916, 5.405)'"   "print '  density = $(v_dens:%.3f) g/cm^3 (exp. 2.65)  E/atom = $(pe/count(all):%.4f) eV'"   "print '--------------------------------------------------'" else   "variable gam equal (pe-count(all)*v_eb)/(2*lx*ly)*16021.766"   "print '--------------------------------------------------'"   "print 'QUARTZ ${pot}: cleaved (0001) surface energy = $(v_gam:%.0f) mJ/m^2'"   "print '--------------------------------------------------'"
