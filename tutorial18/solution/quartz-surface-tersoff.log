# 3) Settings: three potentials, three treatments of the charges
if "${pot} == comb" then   "set type 1 charge  1.2"   "set type 2 charge -0.6"   "pair_style comb"   "pair_coeff * * ffield.comb Si O"   "fix q all qeq/comb 1 0.0001" elif "${pot} == tersoff"   "pair_style tersoff"   "pair_coeff * * SiO.tersoff Si O" else   "pair_style vashishta"   "pair_coeff * * SiO.1990.vashishta Si O"
pair_style tersoff
pair_coeff * * SiO.tersoff Si O
Reading tersoff potential file SiO.tersoff with DATE: 2010-08-16
neighbor 0.5 bin

# 4) Monitoring
group si type 1
24 atoms in group si
group ox type 2
48 atoms in group ox
compute qsi si property/atom q
compute qavsi si reduce ave c_qsi
thermo 100
thermo_style custom step pe press lx lz c_qavsi

# 5) Relax: full cell in bulk mode, atoms only in surface mode
if "${mode} == bulk" then "fix relax all box/relax aniso 0.0 vmax 0.001"
min_style cg
min_modify dmax 0.005 line quadratic
minimize 1.0e-10 1.0e-10 2000 10000
