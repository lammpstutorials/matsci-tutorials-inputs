# 3) Settings: three potentials, three treatments of the charges
if "${pot} == comb" then   "set type 1 charge  1.2"   "set type 2 charge -0.6"   "pair_style comb"   "pair_coeff * * ffield.comb Si O"   "fix q all qeq/comb 1 0.0001" elif "${pot} == tersoff"   "pair_style tersoff"   "pair_coeff * * SiO.tersoff Si O" else   "pair_style vashishta"   "pair_coeff * * SiO.1990.vashishta Si O"
set type 1 charge  1.2
