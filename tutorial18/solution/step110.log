# 3) Carve the step: remove the top trilayer over half the surface.  The
#    z-cut at ztop-2.75 lies in the inter-trilayer gap, the x-cut at lx/2
#    creates two step edges running along y = [001].
variable ztop equal bound(all,zmax)
region terrace block $(lx/2) INF INF INF $(v_ztop-2.75) INF units box
region terrace block 13.012399999999999523 INF INF INF $(v_ztop-2.75) INF units box
region terrace block 13.012399999999999523 INF INF INF 16.412060239999998856 INF units box
delete_atoms region terrace
Deleted 72 atoms, new total = 792

# 4) Settings
set type 1 charge  2.4
