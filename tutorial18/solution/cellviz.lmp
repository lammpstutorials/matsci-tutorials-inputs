# Tutorial 18 -- render the rutile TiO2 structure (avatar figure).
#
# Rebuilds a small rutile block at the relaxed COMB lattice constants and
# renders it ball-and-stick, with the Ti-O bonds inferred from the
# interatomic distances by the autobond feature (cf. Tutorial 9).

units metal
dimension 3
boundary p p p
atom_style charge

lattice custom 1.0 &
    a1 4.6006 0.0 0.0  a2 0.0 4.6006 0.0  a3 0.0 0.0 2.9646 &
    basis 0.0    0.0    0.0 &
    basis 0.5    0.5    0.5 &
    basis 0.3048 0.3048 0.0 &
    basis 0.6952 0.6952 0.0 &
    basis 0.8048 0.1952 0.5 &
    basis 0.1952 0.8048 0.5
region box block 0 2 0 1 0 2
create_box 2 box
create_atoms 1 box basis 1 1 basis 2 1 basis 3 2 basis 4 2 basis 5 2 basis 6 2
mass 1 47.867
mass 2 15.999
pair_style zero 6.0
pair_coeff * *
thermo 1
run 0 post no

write_dump all image rutile-cell.png type type &
    view 80 -70 zoom 2.0 box yes 0.05 size 1000 800 &
    shiny 0.3 ssao yes 4539 0.7 fsaa yes autobond 2.2 0.5 &
    modify backcolor white boxcolor midnightblue &
    adiam 1 1.1 adiam 2 1.5 &
    acolor 1 gray acolor 2 firebrick
