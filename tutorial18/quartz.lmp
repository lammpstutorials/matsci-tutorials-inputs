# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package: 2. Materials Science
# By Simon Gravelle, Mark A. Tschopp, Jacob R. Gissinger, and Axel Kohlmeyer
# Tutorial 18: 4. One oxide, three potentials -- alpha-quartz SiO2
#
# Run alpha-quartz with three bundled potentials that treat charges in
# three different ways: COMB (self-consistent charge equilibration), the
# SiO Tersoff of Munetoh et al. (no charges at all -- charge transfer is
# folded into the bond order), and the Vashishta potential (fixed effective
# charges baked into the parameters).  Select with the index variables:
#     lmp -in quartz.lmp -var pot tersoff
#     lmp -in quartz.lmp -var pot comb -var mode surface
# mode = bulk    : relax the cell, report lattice constants and density
# mode = surface : cleave a (0001) slab at the potential's own bulk lattice
#                  constants, relax, report the surface energy
# Structure: Levien et al., Am. Mineral. 65, 920 (1980), as in the LAMMPS
# alpha-quartz qtb example; the hexagonal cell is doubled along y into an
# orthorhombic 18-atom supercell so the box stays orthogonal.

# 1) Initialization
variable pot  index comb        # comb | tersoff | vashishta
variable mode index bulk        # bulk | surface
units metal
dimension 3
atom_style charge
if "${mode} == bulk" then "boundary p p p" else "boundary p p s"

# 2) System definition
# per-potential relaxed bulk lattice constants and cohesive energies
# (from the bulk runs of this input; experiment: a = 4.916, c = 5.405)
if "${pot} == comb" then &
  "variable qa equal 4.9210" "variable qc equal 5.4078" "variable eb equal -6.9228" &
elif "${pot} == tersoff" &
  "variable qa equal 5.0820" "variable qc equal 5.5277" "variable eb equal -6.6979" &
else &
  "variable qa equal 4.8291" "variable qc equal 5.3087" "variable eb equal -9.1804"
# in bulk mode, start from the experimental cell instead and let it relax
if "${mode} == bulk" then "variable qa equal 4.916" "variable qc equal 5.4054"
variable qb equal ${qa}*0.8660254
lattice custom 1.0 &
    a1 ${qa} 0.0 0.0  a2 $(-0.5*v_qa) $(v_qb) 0.0  a3 0.0 0.0 ${qc} &
    basis 0.469700 0.000000 0.000000 &
    basis 0.000000 0.469700 0.666667 &
    basis 0.530300 0.530300 0.333333 &
    basis 0.413500 0.266900 0.119100 &
    basis 0.266900 0.413500 0.547567 &
    basis 0.733100 0.146600 0.785767 &
    basis 0.586500 0.853400 0.214233 &
    basis 0.853400 0.586500 0.452433 &
    basis 0.146600 0.733100 0.880900 &
    origin 0.0 0.0 0.05
region box block 0 $(2*v_qa) 0 $(2*v_qb) 0 $(2*v_qc) units box
create_box 2 box
create_atoms 1 box basis 1 1 basis 2 1 basis 3 1 &
    basis 4 2 basis 5 2 basis 6 2 basis 7 2 basis 8 2 basis 9 2
mass 1 28.0855
mass 2 15.999

# 3) Settings: three potentials, three treatments of the charges
if "${pot} == comb" then &
  "set type 1 charge  1.2" &
  "set type 2 charge -0.6" &
  "pair_style comb" &
  "pair_coeff * * ffield.comb Si O" &
  "fix q all qeq/comb 1 0.0001" &
elif "${pot} == tersoff" &
  "pair_style tersoff" &
  "pair_coeff * * SiO.tersoff Si O" &
else &
  "pair_style vashishta" &
  "pair_coeff * * SiO.1990.vashishta Si O"
neighbor 0.5 bin

# 4) Monitoring
group si type 1
group ox type 2
compute qsi si property/atom q
compute qavsi si reduce ave c_qsi
thermo 100
thermo_style custom step pe press lx lz c_qavsi

# 5) Relax: full cell in bulk mode, atoms only in surface mode
if "${mode} == bulk" then "fix relax all box/relax aniso 0.0 vmax 0.001"
min_style cg
min_modify dmax 0.005 line quadratic
minimize 1.0e-10 1.0e-10 2000 10000

# 6) Report
if "${mode} == bulk" then &
  "variable arel equal lx/2" &
  "variable crel equal lz/2" &
  "variable dens equal mass(all)/vol*1.66054" &
  "print '--------------------------------------------------'" &
  "print 'QUARTZ ${pot}: a = $(v_arel:%.4f)  c = $(v_crel:%.4f)  (exp. 4.916, 5.405)'" &
  "print '  density = $(v_dens:%.3f) g/cm^3 (exp. 2.65)  E/atom = $(pe/count(all):%.4f) eV'" &
  "print '--------------------------------------------------'" &
else &
  "variable gam equal (pe-count(all)*v_eb)/(2*lx*ly)*16021.766" &
  "print '--------------------------------------------------'" &
  "print 'QUARTZ ${pot}: cleaved (0001) surface energy = $(v_gam:%.0f) mJ/m^2'" &
  "print '--------------------------------------------------'"
if "${mode} == surface && ${pot} == comb" then "write_data qsurface.data"
