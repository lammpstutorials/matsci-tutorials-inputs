variable gam equal (pe-v_natoms*v_ecoh)/(2*v_area)*16021.766

# 7) Interlayer relaxation of the two outermost layers
variable ztop equal bound(all,zmax)
region r1 block INF INF INF INF $(v_ztop-0.5*v_dlay) INF units box
region r1 block INF INF INF INF 18.29107331798019942 INF units box
region r2 block INF INF INF INF $(v_ztop-1.5*v_dlay) $(v_ztop-0.5*v_dlay) units box
region r2 block INF INF INF INF 16.250248317980197754 $(v_ztop-0.5*v_dlay) units box
region r2 block INF INF INF INF 16.250248317980197754 18.29107331798019942 units box
group L1 region r1
32 atoms in group L1
group L2 region r2
32 atoms in group L2
variable d12 equal (xcm(L1,z)-xcm(L2,z)-v_dlay)/v_dlay*100

print "--------------------------------------------------"
