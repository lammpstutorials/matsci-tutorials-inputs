unfix relaxbox

# 5) Grain-boundary energy.  With PBC along y the cell contains TWO equivalent
# (111) boundaries (at y = 0 and across the periodic seam), hence the factor 2.
variable ecoh   equal -4.122435     # bcc Fe cohesive energy (eV/atom)
variable natoms equal count(all)
variable area   equal lx*lz
variable egb    equal (pe-v_natoms*v_ecoh)/(2.0*v_area)
variable egb_mJ equal v_egb*16021.766
print "GB area (one boundary): $(v_area:%.3f) Ang^2, atoms: ${natoms}"
GB area (one boundary): 226.598 Ang^2, atoms: 1534
print "GB energy: $(v_egb:%.5f) eV/Ang^2 = $(v_egb_mJ:%.1f) mJ/m^2"
