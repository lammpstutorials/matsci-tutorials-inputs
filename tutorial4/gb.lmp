# LAMMPS Input File
# Licensed under CC BY 4.0
# A Set of Materials-Science Tutorials for the LAMMPS Simulation Package
# Modernized recreation of the MSU/CAVS tutorials by Mark A. Tschopp
# Tutorial 4: build a Sigma5(310) symmetric tilt grain boundary in fcc Al.

# lattice constant (equilibrium value for the Zhou potential, see Tutorial 1)
variable a0 equal 4.0817

# Sigma5(310) STGB geometry (box units):
#   x along [0 3 1]  -> period sqrt(10)*a0   (in the GB plane)
#   y along [0 -1 3] -> period sqrt(10)*a0   (grain-boundary normal)
#   z along [1 0 0]  -> period a0            (the [100] tilt axis)
variable bx equal sqrt(10)*v_a0
variable bz equal v_a0
variable ny equal 4                       # number of [0 -1 3] periods per grain
variable by equal v_ny*sqrt(10)*v_a0

# 1) Initialization
units metal
dimension 3
boundary p p p
atom_style atomic

# 2) System definition: two mis-oriented grains meeting at y = 0
lattice fcc ${a0}
region box block 0 ${bx} -${by} ${by} 0 ${bz} units box
create_box 2 box

region upper block INF INF 0.0 ${by} INF INF units box
lattice fcc ${a0} orient x 0 3 1 orient y 0 -1 3 orient z 1 0 0
create_atoms 1 region upper

region lower block INF INF -${by} 0.0 INF INF units box
lattice fcc ${a0} orient x 0 3 -1 orient y 0 1 3 orient z 1 0 0
create_atoms 2 region lower

group upper type 1
group lower type 2

# 3) Settings
pair_style eam/alloy
pair_coeff * * Al_zhou.eam.alloy Al Al

# remove atoms that nearly coincide across the grain boundary
delete_atoms overlap 0.35 lower upper

compute csym all centro/atom fcc
compute eng  all pe/atom

# 4) Monitoring
thermo 50
thermo_style custom step pe press pxx pyy pzz lx ly lz

# 5) Minimization: relax the atoms, then let the box relax along the GB normal (y)
min_style cg
minimize 1.0e-12 1.0e-12 10000 100000
fix relax all box/relax y 0.0 vmax 0.001
minimize 1.0e-12 1.0e-12 10000 100000

# grain-boundary energy: (E_total - N E_coh) / (2 A), two GBs in the periodic cell
# E_coh is the perfect-crystal cohesive energy for this potential (Tutorial 1)
variable ecoh   equal -3.5800
variable gbarea equal lx*lz
variable gbe    equal (pe-v_ecoh*count(all))/(2.0*v_gbarea)   # eV/Ang^2
variable gbeJ   equal v_gbe*16021.766                          # mJ/m^2
print "----------------------------------------------------"
print "Number of atoms       = $(count(all))"
print "Grain-boundary energy = $(v_gbeJ:%.1f) mJ/m^2"
print "----------------------------------------------------"

# visualization: replicate three GB periods along x (figure only; the energy
# above is per unit area and independent of this), then render looking down
# the [100] tilt axis, colored by centrosymmetry
unfix relax
replicate 3 1 1
run 0
write_dump all image gb-structure.png c_csym type adiam 2.6 &
    view 0 0 up 0 1 0 zoom 7.0 size 720 460 &
    shiny 0.15 ssao yes 4539 0.5 fsaa yes &
    modify backcolor white boxcolor midnightblue amap 0.0 12.0 ca 0.0 2 min steelblue max firebrick
